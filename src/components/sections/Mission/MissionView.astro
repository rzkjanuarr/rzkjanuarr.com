---
/* Tampilan section misi */
import SectionLabel from "../../ui/SectionLabel.astro";
import { missionData } from "./MissionViewModel.astro";

const { label, title, description } = missionData;
---

<section class="py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <div class="max-w-3xl">
      <SectionLabel label={label} />
      <h2 class="text-headline mt-4 mb-8">{title}</h2>
      <p class="text-body-lg text-text-secondary">{description}</p>
    </div>
  </div>
</section>
