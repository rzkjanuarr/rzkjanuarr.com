---
/* Tampilan navigasi utama */
import { navbarData } from "./NavbarViewModel.astro";

const { brand, links } = navbarData;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-[rgba(250,251,255,0.9)] backdrop-blur-md"
>
  <div
    class="max-w-6xl mx-auto px-4 md:px-8 flex items-center justify-between h-16"
  >
    <!-- Logo -->
    <a href="/" class="font-display text-xl font-bold tracking-tight">
      {brand}
    </a>

    <!-- Navigasi desktop -->
    <div class="hidden md:flex items-center gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors duration-200"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Hamburger button mobile -->
    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-10 h-10"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</nav>

<!-- Menu mobile fullscreen - di luar nav agar z-index benar -->
<div
  id="mobile-menu"
  class="hidden md:hidden fixed inset-0 top-0 z-[999] bg-[rgba(250,251,255,0.85)] backdrop-blur-2xl"
>
  <div class="max-w-6xl mx-auto px-4 md:px-8 flex items-center justify-between h-16">
    <a href="/" class="font-display text-xl font-bold tracking-tight">{brand}</a>
    <button
      id="menu-close"
      class="flex items-center justify-center w-10 h-10"
      aria-label="Close menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div class="flex flex-col items-center justify-center gap-8 pt-20">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="text-2xl font-medium text-text-secondary hover:text-text-primary transition-colors duration-200 mobile-link"
        >
          {link.label}
        </a>
      ))
    }
  </div>
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const menuClose = document.getElementById("menu-close");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  function openMenu() {
    menu?.classList.remove("hidden");
  }
  function closeMenu() {
    menu?.classList.add("hidden");
  }

  toggle?.addEventListener("click", openMenu);
  menuClose?.addEventListener("click", closeMenu);
  mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));
</script>
