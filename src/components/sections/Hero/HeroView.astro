---
/* Tampilan hero section utama - layout bertumpuk seperti referensi Andy */
import { heroData } from "./HeroViewModel.astro";
import { clientsData } from "./HeroViewModel.astro";

const { greeting, name, role, image } = heroData;
const { label, clients } = clientsData;
---

<section
  id="hero-section"
  class="relative pt-36 pb-8 md:pt-48 md:pb-16 overflow-hidden"
>
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <!-- Wrapper utama: mobile stacked, desktop overlapping -->
    <div
      class="relative flex flex-col items-center text-center gap-0 md:gap-[60px]"
    >
      <!-- Layer 1: Teks "Hi, I'am RIZKI" - slide dari kiri -->
      <h1
        id="hero-greeting"
        class="hero-display relative z-10 whitespace-nowrap opacity-0"
      >
        <span class="text-text-primary">{greeting} </span>
        <span class="text-text-brand">{name}</span>
      </h1>

      <!-- Layer 2: Gambar hero - fade in -->
      <div
        id="hero-image"
        class="relative z-20 md:absolute md:inset-0 flex items-center justify-center -my-4 md:my-0 opacity-0"
      >
        <img
          src={image}
          alt="Foto profil Rizki - Android Engineer"
          class="w-40 h-40 md:w-[700px] md:h-[700px] object-contain drop-shadow-lg"
        />
      </div>

      <!-- Layer 3: Teks "ANDROID ENGINEER" - slide dari kanan -->
      <h2
        id="hero-role"
        class="hero-display hero-role relative z-30 text-text-primary whitespace-nowrap opacity-0"
      >
        {role}
      </h2>
    </div>

    <!-- Gradient fade dari bawah ke atas agar clients terlihat -->
    <div
      class="absolute bottom-0 left-0 right-0 z-30 h-[40%] hero-fade pointer-events-none"
    >
    </div>

    <!-- Clients / History Work - di bawah hero -->
    <div id="hero-clients" class="relative z-40 mt-12 md:mt-16 pt-8 opacity-0">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16">
        <p class="text-sm text-text-secondary whitespace-nowrap">{label}</p>
        <div class="flex items-center gap-2 md:gap-2 flex-wrap justify-center">
          {
            clients.map((client) =>
              client.url ? (
                <a href={client.url} target="_blank" rel="noopener noreferrer">
                  <img
                    src={client.logo}
                    alt={`Logo ${client.name}`}
                    loading="lazy"
                    class="h-8 md:h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-200 cursor-pointer"
                  />
                </a>
              ) : (
                <img
                  src={client.logo}
                  alt={`Logo ${client.name}`}
                  loading="lazy"
                  class="h-8 md:h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-200"
                />
              ),
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Tipografi hero yang responsif dan selalu satu baris */
  .hero-display {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 8vw, 7.5rem);
    font-weight: 400;
    line-height: 1.1;
  }

  /* Shadow putih agar teks terlihat di atas gambar */
  .hero-role {
    text-shadow:
      0 0 20px rgba(255, 255, 255, 0.9),
      0 0 40px rgba(255, 255, 255, 0.7),
      0 0 80px rgba(255, 255, 255, 0.5);
  }

  /* Gradient fade dari bawah section ke atas */
  .hero-fade {
    background: linear-gradient(
      to top,
      rgba(250, 251, 255, 1) 30%,
      rgba(250, 251, 255, 0) 100%
    );
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  /* Timeline animasi hero: elemen muncul berurutan saat halaman load */
  const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

  tl.fromTo(
    "#hero-greeting",
    { opacity: 0, x: -100 },
    { opacity: 1, x: 0, duration: 0.8 },
  )
    .fromTo(
      "#hero-image",
      { opacity: 0, scale: 0.8 },
      { opacity: 1, scale: 1, duration: 0.8 },
      "-=0.4",
    )
    .fromTo(
      "#hero-role",
      { opacity: 0, x: 100 },
      { opacity: 1, x: 0, duration: 0.8 },
      "-=0.4",
    )
    .fromTo(
      "#hero-clients",
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.6 },
      "-=0.2",
    );

  /* Animasi keluar berurutan saat scroll ke bawah */
  const exitTl = gsap.timeline({
    scrollTrigger: {
      trigger: "#hero-section",
      start: "top top",
      end: "bottom top",
      scrub: 0.5,
    },
  });

  exitTl
    .to("#hero-greeting", { opacity: 0, x: -100, duration: 0.3 })
    .to("#hero-image", { opacity: 0, scale: 0.8, duration: 0.3 }, "-=0.1")
    .to("#hero-role", { opacity: 0, x: 100, duration: 0.3 }, "-=0.1")
    .to("#hero-clients", { opacity: 0, y: 30, duration: 0.3 }, "-=0.1");
</script>
