---
/* Tampilan section proyek */
import SectionLabel from "../../ui/SectionLabel.astro";
import ProjectCard from "../../ui/ProjectCard.astro";
import Button from "../../ui/Button.astro";
import { projectsData } from "./ProjectsViewModel.astro";

const { label, title, projects, cta } = projectsData;
---

<section id="projects" class="py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <SectionLabel label={label} />
    <h2 class="text-headline mt-4 mb-12">{title}</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      {
        projects.map((project) => (
          <ProjectCard
            image={project.image}
            title={project.title}
            description={project.description}
            alt={project.alt}
            slug={project.slug}
            playstore={project.playstore}
          />
        ))
      }
    </div>
  </div>
</section>
