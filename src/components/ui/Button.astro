---
/* Komponen tombol yang bisa digunakan ulang */
interface Props {
  variant?: "primary" | "outline";
  href?: string;
  class?: string;
}

const { variant = "primary", href, class: className } = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center px-6 py-3 rounded-full text-sm font-semibold transition-all duration-200 cursor-pointer";

const variantClasses = {
  primary:
    "bg-btn-primary text-white hover:bg-btn-primary-hover active:bg-btn-primary-pressed",
  outline:
    "border border-text-primary text-text-primary hover:bg-text-primary hover:text-white",
};
---

{
  href ? (
    <a
      href={href}
      class:list={[baseClasses, variantClasses[variant], className]}
    >
      <slot />
    </a>
  ) : (
    <button class:list={[baseClasses, variantClasses[variant], className]}>
      <slot />
    </button>
  )
}
