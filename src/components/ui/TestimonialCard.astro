---
/* Komponen kartu testimoni yang bisa digunakan ulang */
interface Props {
  avatar: string;
  name: string;
  company: string;
  testimonial: string;
  rating: number;
}

const { avatar, name, company, testimonial, rating } = Astro.props;

const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<div
  class="flex flex-col gap-4 p-6 rounded-2xl bg-surface-secondary border border-border-100"
>
  <div class="flex items-center gap-4">
    <img
      src={avatar}
      alt={`Foto ${name}`}
      loading="lazy"
      class="w-12 h-12 rounded-full object-cover"
    />
    <div class="flex flex-col gap-1">
      <p class="text-text-secondary text-sm leading-relaxed">{testimonial}</p>
      <div class="flex gap-0.5 mt-1">
        {
          stars.map((filled) => (
            <span class={filled ? "text-yellow-400" : "text-gray-300"}>★</span>
          ))
        }
      </div>
      <p class="text-sm text-text-secondary mt-1">
        <span class="font-semibold text-text-primary">{name}</span> — {company}
      </p>
    </div>
  </div>
</div>
